---
interface Props {
  label: string;
  title: string;
  titleItalic?: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
  dark?: boolean;
  bgImage?: string;
  bgOverlay?: string;
  panelId?: string;
}

const {
  label,
  title,
  titleItalic,
  subtitle,
  ctaLabel,
  ctaHref,
  dark = true,
  bgImage,
  bgOverlay = 'rgba(0,0,0,0.68)',
  panelId,
} = Astro.props;

const isPanel = !!panelId;
const hasBg = !!bgImage;
const fg    = '#fff';
const muted = 'rgba(255,255,255,0.6)';
---

{isPanel ? (
  <!-- Full-screen interactive-section panel — usa global-bg + overlay color -->
  <div
    class="interactive-section photo-text-shadow"
    id={`panel-${panelId}`}
    role="region"
    aria-label={label}
  >
    <!-- Overlay sutil sobre el global-bg persistente -->
    <div
      class="section-bg-overlay"
      style={`position:absolute;inset:0;z-index:0;pointer-events:none;background:${bgOverlay}`}
      aria-hidden="true"
    ></div>
    <div class="section-panel-content">
      <div class="container-wide">
        <div class="label-mono reveal mb-6" style="color:rgba(255,255,255,0.5)">{label}</div>
        <h1
          class="reveal reveal-delay-1 font-bold leading-tight tracking-tight"
          style="font-size:clamp(1.7rem,7vw,7.5rem);color:#fff;letter-spacing:-0.02em;max-width:1100px;text-shadow:0 2px 12px rgba(0,0,0,0.4)"
        >
          {title}
          {titleItalic && (
            <><br /><em style="font-family:var(--font-serif);font-weight:400;font-style:italic;letter-spacing:-0.01em">{titleItalic}</em></>
          )}
        </h1>
        {subtitle && (
          <p
            class="reveal reveal-delay-2"
            style="color:rgba(255,255,255,0.65);max-width:540px;line-height:1.9;font-size:clamp(0.85rem,2.5vw,1.15rem);margin-top:2rem"
          >
            {subtitle}
          </p>
        )}
        {ctaLabel && ctaHref && (
          <div class="reveal reveal-delay-3" style="margin-top:2.5rem">
            <a
              href={ctaHref}
              class="ph-cta inline-flex items-center gap-3 px-8 py-4"
              style="background:#fff;color:#000;font-family:var(--font-mono);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase"
            >
              {ctaLabel}
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
) : (
  <!-- Legacy fallback: normal-flow section -->
  <section
    class={hasBg ? 'page-hero-photo' : ''}
    style={`background:${dark ? '#000' : '#fff'};padding-top:clamp(5rem,16vw,12rem);padding-bottom:clamp(4rem,8vw,7rem);border-bottom:1px solid ${dark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.07)'}`}
  >
    {hasBg && (
      <div
        class="page-hero-photo-bg"
        style={`background-image:url('${bgImage}');--hero-overlay:${bgOverlay}`}
        aria-hidden="true"
      ></div>
    )}
    <div class="container-wide">
      <div class={`${(hasBg || dark) ? 'label-mono' : 'label-mono-light'} reveal mb-6`}>{label}</div>
      <h1
        class="reveal reveal-delay-1 font-bold leading-tight tracking-tight"
        style={`font-size:clamp(1.7rem,7vw,7.5rem);color:${fg};letter-spacing:-0.02em;max-width:1100px${hasBg ? ';text-shadow:0 2px 12px rgba(0,0,0,0.4)' : ''}`}
      >
        {title}
        {titleItalic && (
          <><br /><em style="font-family:var(--font-serif);font-weight:400;font-style:italic;letter-spacing:-0.01em">{titleItalic}</em></>
        )}
      </h1>
      {subtitle && (
        <p class="reveal reveal-delay-2 text-sm leading-relaxed mt-8" style={`color:${muted};max-width:540px;line-height:1.9`}>
          {subtitle}
        </p>
      )}
      {ctaLabel && ctaHref && (
        <div class="reveal reveal-delay-3 mt-10">
          <a
            href={ctaHref}
            class="ph-cta inline-flex items-center gap-3 px-8 py-4"
            style={`background:${fg};color:#000;font-family:var(--font-mono);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase`}
          >
            {ctaLabel}
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      )}
    </div>
  </section>
)}

<style>
  .ph-cta {
    transition: background 0.25s ease, color 0.25s ease, outline 0.25s ease;
  }
  .ph-cta:hover {
    background: transparent !important;
    outline: 1px solid currentColor;
    color: #fff !important;
  }
</style>
