---
import type { Lang } from '../i18n/translations';
import { translations } from '../i18n/translations';

interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;
const t = translations[lang].nav;

const pathname = Astro.url.pathname;

// Strip lang prefix to get base path for language switcher
const knownLangs: Lang[] = ['es', 'pt'];
let basePath = pathname;
for (const l of knownLangs) {
  if (basePath === `/${l}` || basePath === `/${l}/`) { basePath = '/'; break; }
  if (basePath.startsWith(`/${l}/`)) { basePath = basePath.slice(l.length + 1); break; }
}
const langUrls: Record<Lang, string> = {
  en: basePath,
  es: basePath === '/' ? '/es/' : `/es${basePath}`,
  pt: basePath === '/' ? '/pt/' : `/pt${basePath}`,
};

// Prefix for links
const p = lang === 'en' ? '' : `/${lang}`;

const links = [
  {
    label: t.system,
    href: `${p}/system/`,
    icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>`,
  },
  {
    label: t.packages,
    href: `${p}/packages/`,
    icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="22.08" x2="12" y2="12" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    label: t.contacto,
    href: `${p}/contacto/`,
    icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
];

const homeHref = lang === 'en' ? '/' : `/${lang}/`;
---

<!-- ═══════════════════════════════════════════════════
     LEFT RAIL (desktop only)
════════════════════════════════════════════════════ -->
<nav id="left-rail" aria-label="Main navigation">

  <a href={homeHref} class="rail-logo" aria-label="JiveShed — home">
    <span class="rail-logo-mark" aria-hidden="true">
      {[...'jiveshed'].map(l => <span>{l}</span>)}
    </span>
  </a>

  <div class="rail-links-group">
    <a
      href={homeHref}
      class={`rail-link ${pathname === homeHref || pathname === '/' && lang === 'en' ? 'is-active' : ''}`}
      aria-label={t.home}
      aria-current={pathname === homeHref ? 'page' : undefined}
    >
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      <span class="rail-tooltip">{t.home}</span>
    </a>
    {links.map(link => (
      <a
        href={link.href}
        class={`rail-link ${pathname.startsWith(link.href) ? 'is-active' : ''}`}
        aria-label={link.label}
        aria-current={pathname.startsWith(link.href) ? 'page' : undefined}
      >
        <Fragment set:html={link.icon} />
        <span class="rail-tooltip">{link.label}</span>
      </a>
    ))}

    <a
      href="mailto:hello@jiveshed.com?subject=JiveShed%20Growth%20Audit"
      class="rail-link rail-link-cta"
      aria-label={t.growthAudit}
    >
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
      </svg>
      <span class="rail-tooltip">{t.growthAudit}</span>
    </a>
  </div>

  <!-- Language switcher -->
  <div class="rail-lang-switcher" aria-label="Language">
    {(['en', 'es', 'pt'] as const).map(l => (
      <a
        href={langUrls[l]}
        class={`rail-lang-btn ${lang === l ? 'is-active' : ''}`}
        aria-label={l.toUpperCase()}
        aria-current={lang === l ? 'true' : undefined}
      >{l.toUpperCase()}</a>
    ))}
  </div>
</nav>


<!-- ═══════════════════════════════════════════════════
     MOBILE BOTTOM TAB BAR
════════════════════════════════════════════════════ -->
<nav id="bottom-tabs" aria-label="Mobile navigation">
  <a href={homeHref} class={`btab ${pathname === homeHref ? 'is-active' : ''}`} aria-label={t.home}>
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
    </svg>
    <span>{t.home}</span>
  </a>

  {links.map(link => (
    <a
      href={link.href}
      class={`btab ${pathname.startsWith(link.href) ? 'is-active' : ''}`}
      aria-label={link.label}
      aria-current={pathname.startsWith(link.href) ? 'page' : undefined}
    >
      <Fragment set:html={link.icon} />
      <span>{link.label}</span>
    </a>
  ))}

  <a
    href="mailto:hello@jiveshed.com?subject=JiveShed%20Growth%20Audit"
    class="btab btab-audit"
    aria-label={t.growthAudit}
  >
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
    </svg>
    <span>{lang === 'en' ? 'Audit' : lang === 'es' ? 'Auditoría' : 'Auditoria'}</span>
  </a>
</nav>


<style>
#left-rail {
  position: fixed;
  top: 0;
  left: 0;
  bottom: var(--footer-h);
  width: var(--rail-w);
  z-index: 240;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0.75rem 0 0.75rem;
  background: #000;
  border-right: 1px solid rgba(255,255,255,0.07);
  gap: 0;
}

.rail-logo {
  position: relative;
  width: 100%;
  height: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  padding: 1.1rem 0 1rem;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  flex-shrink: 0;
}
.rail-logo-mark {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  line-height: 1;
  color: rgba(255, 255, 255, 0.9);
  transition: opacity 0.2s ease;
}
.rail-logo-mark > span {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 16px;
  border: 1px solid rgba(255,255,255,0.12);
  line-height: 1;
}
.rail-logo:hover .rail-logo-mark { opacity: 0.65; }

@media (max-width: 1023px) {
  #left-rail { display: none; }
}

.rail-links-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  width: 100%;
  gap: 0;
}

.rail-link {
  position: relative;
  width: 100%;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.72);
  text-decoration: none;
  transition: color 0.2s ease, background 0.2s ease;
  cursor: pointer;
}
.rail-link:hover {
  color: #fff;
  background: rgba(255,255,255,0.08);
}
.rail-link.is-active {
  color: #fff;
}
.rail-link.is-active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 25%;
  bottom: 25%;
  width: 2px;
  background: #fff;
  border-radius: 0 1px 1px 0;
}
.rail-link-cta { color: var(--js-coral); margin-top: auto; }
.rail-link-cta:hover { color: #fff; background: rgba(255,107,61,0.15); }

.rail-lang-switcher {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 0.6rem 0 0.75rem;
  border-top: 1px solid rgba(255,255,255,0.07);
  width: 100%;
  margin-top: auto;
}
.rail-lang-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 22px;
  font-family: var(--font-mono);
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-decoration: none;
  color: rgba(255,255,255,0.38);
  border-radius: 2px;
  transition: color 0.15s ease, background 0.15s ease;
}
.rail-lang-btn:hover { color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.08); }
.rail-lang-btn.is-active { color: #fff; background: rgba(255,255,255,0.12); }

.rail-tooltip {
  position: absolute;
  left: calc(100% + 10px);
  top: 50%;
  transform: translateY(-50%) translateX(-4px);
  background: rgba(20,20,20,0.96);
  border: 1px solid rgba(255,255,255,0.18);
  color: #fff;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0.4rem 0.7rem;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.15s ease, transform 0.15s ease;
  backdrop-filter: blur(8px);
  z-index: 9;
}
.rail-link:hover .rail-tooltip {
  opacity: 1;
  transform: translateY(-50%) translateX(0);
}


#bottom-tabs {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: var(--btab-h);
  z-index: 235;
  background: rgba(0,0,0,0.92);
  border-top: 1px solid rgba(255,255,255,0.1);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 -4px 24px rgba(0,0,0,0.4);
  flex-direction: row;
  align-items: stretch;
  justify-content: center;
  overflow-x: auto;
  scrollbar-width: none;
}
#bottom-tabs::-webkit-scrollbar { display: none; }

@media (max-width: 1023px) {
  #bottom-tabs { display: flex; }
}

.btab {
  flex: 0 0 auto;
  min-width: 80px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.3rem;
  color: rgba(255,255,255,0.72);
  text-decoration: none;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0.5rem 0.5rem;
  transition: color 0.2s ease;
  position: relative;
  font-family: inherit;
}
.btab:hover { color: #fff; }
.btab.is-active { color: #fff; }
.btab.is-active::before {
  content: '';
  position: absolute;
  top: 0;
  left: 20%;
  right: 20%;
  height: 2px;
  background: var(--js-coral);
}

.btab span {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  line-height: 1;
}

.btab-audit { color: var(--js-coral); }
.btab-audit:hover,
.btab-audit.is-active { color: #fff; }

@media (max-width: 390px) {
  .btab span { display: none; }
  #bottom-tabs { height: 52px; }
  .btab { min-width: 56px; }
}
</style>


<script>
  const bottomTabs = document.getElementById('bottom-tabs');
  const activeTab  = bottomTabs?.querySelector<HTMLElement>('.btab.is-active');
  if (bottomTabs && activeTab) {
    const tabRect   = activeTab.getBoundingClientRect();
    const barRect   = bottomTabs.getBoundingClientRect();
    const tabCenter = tabRect.left - barRect.left + tabRect.width / 2;
    bottomTabs.scrollLeft = bottomTabs.scrollLeft + tabCenter - bottomTabs.clientWidth / 2;
  }
</script>
