---
import type { Lang } from '../../../i18n/translations';
import { translations } from '../../../i18n/translations';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import InteractiveSection from '../../../components/InteractiveSection.astro';
import Footer from '../../../components/Footer.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'pt' } }];
}

const { lang } = Astro.params as { lang: Lang };
const t = translations[lang];
const s = t.system;
---

<Layout title={s.metaTitle} description={s.metaDesc} lang={lang} pageTabs={s.tabs}>
  <Nav lang={lang} />
  <main>
    <h1 class="sr-only">{s.h1}</h1>

    <!-- ═══ PANEL 01: El Problema ═══ -->
    <InteractiveSection id="problem" label={s.tabs[0].label} imageUrl="" overlayColor="var(--js-overlay-coral)">
      <div class="container-wide flex flex-col" style="gap:clamp(1.25rem,2.5vw,2rem)">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <div class="label-mono reveal mb-3" style="color:rgba(255,255,255,0.5)">{s.probLabel}</div>
            <h2 class="reveal reveal-delay-1 font-bold leading-tight tracking-tight" style="font-size:clamp(1.75rem,4vw,3.25rem);color:#fff;letter-spacing:-0.02em">
              {s.probHeading} <em style="font-family:var(--font-serif);font-weight:400;font-style:italic">{s.probHeadingItalic}</em>
            </h2>
          </div>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-12">
          <div class="reveal reveal-delay-2 flex flex-col gap-2" style="padding:1.5rem;background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.12)">
            {s.problemLines.map(line => <p style="color:rgba(255,255,255,0.85);font-size:clamp(0.95rem,1.4vw,1.1rem);line-height:1.5">{line}</p>)}
          </div>
          <div class="reveal reveal-delay-3 flex flex-col" style="border-top:1px solid rgba(255,255,255,0.18)">
            {s.problemConsequences.map(c => (
              <div class="grid items-center py-3 border-b" style="border-color:rgba(255,255,255,0.1);grid-template-columns:1fr auto 1fr;gap:0.75rem">
                <p style="color:rgba(255,255,255,0.78);font-size:0.85rem;text-align:right">{c.lead}</p>
                <span style="color:var(--js-coral);font-family:var(--font-mono);font-size:0.7rem">→</span>
                <p class="font-bold" style="color:#fff;font-size:0.9rem;letter-spacing:-0.01em">{c.fail}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </InteractiveSection>

    <!-- ═══ PANEL 02: El Sistema ═══ -->
    <InteractiveSection id="system" label={s.tabs[1].label} imageUrl="" overlayColor="var(--js-overlay-blue)">
      <div class="container-wide flex flex-col" style="gap:clamp(1.5rem,3vw,2.5rem)">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 items-end">
          <div>
            <div class="label-mono reveal mb-3" style="color:rgba(255,255,255,0.5)">{s.sysLabel}</div>
            <h2 class="reveal reveal-delay-1 font-bold leading-tight tracking-tight" style="font-size:clamp(1.75rem,4vw,3.25rem);color:#fff;letter-spacing:-0.02em">
              {s.sysHeading} <em style="font-family:var(--font-serif);font-weight:400;font-style:italic">{s.sysHeadingItalic}</em>
            </h2>
          </div>
          <p class="reveal reveal-delay-2 hidden lg:block max-w-xs" style="color:rgba(255,255,255,0.65);font-size:0.8rem;border-left:1px solid rgba(255,255,255,0.2);padding-left:1rem">
            {s.sysSide}
          </p>
        </div>
        <div class="reveal reveal-delay-2 flex flex-wrap items-stretch" style="gap:1px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.12)">
          {s.systemSteps.map((step, i) => (
            <div class="flex-1 flex flex-col items-start gap-2" style={`min-width:120px;padding:1rem 1.25rem;background:rgba(0,0,0,${0.35 + i * 0.04})`}>
              <span style="font-family:var(--font-mono);font-size:0.55rem;letter-spacing:0.14em;color:rgba(255,255,255,0.4);font-weight:700">{step.num}</span>
              <h3 class="font-bold leading-tight" style="font-size:clamp(0.85rem,1.3vw,1rem);color:#fff;letter-spacing:-0.01em">{step.label}</h3>
            </div>
          ))}
        </div>
        <p class="reveal reveal-delay-3" style="color:rgba(255,255,255,0.75);font-size:0.95rem;max-width:48rem">{s.sysBody}</p>
      </div>
    </InteractiveSection>

    <!-- ═══ PANEL 03: A Quién Ayudamos ═══ -->
    <InteractiveSection id="who" label={s.tabs[2].label} imageUrl="" overlayColor="var(--js-overlay-green)">
      <div class="container-wide flex flex-col" style="gap:clamp(1.5rem,3vw,2.5rem)">
        <div>
          <div class="label-mono reveal mb-3" style="color:rgba(255,255,255,0.5)">{s.whoLabel}</div>
          <h2 class="reveal reveal-delay-1 font-bold leading-tight tracking-tight" style="font-size:clamp(1.75rem,4vw,3.25rem);color:#fff;letter-spacing:-0.02em;max-width:48rem">
            {s.whoHeading} <em style="font-family:var(--font-serif);font-weight:400;font-style:italic">{s.whoHeadingItalic}</em> {s.whoHeadingSuffix}
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-px" style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.12)">
          {s.industries.map((ind, i) => (
            <div class={`reveal reveal-delay-${i+1} flex flex-col gap-3 p-6 md:p-7`} style="background:rgba(0,0,0,0.4)">
              <span style="font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.14em;color:var(--js-signal-green);font-weight:700">{ind.num}</span>
              <h3 class="font-bold leading-tight" style="font-size:clamp(1.05rem,1.7vw,1.3rem);color:#fff;letter-spacing:-0.01em">{ind.name}</h3>
              <p class="leading-relaxed flex-1" style="color:rgba(255,255,255,0.72);font-size:0.85rem">{ind.note}</p>
            </div>
          ))}
        </div>
      </div>
    </InteractiveSection>

    <!-- ═══ PANEL 04: Qué Construimos ═══ -->
    <InteractiveSection id="what" label={s.tabs[3].label} imageUrl="" overlayColor="var(--js-overlay-charcoal)">
      <div class="container-wide flex flex-col" style="gap:clamp(1.25rem,2.5vw,2rem)">
        <div>
          <div class="label-mono reveal mb-3" style="color:rgba(255,255,255,0.5)">{s.whatLabel}</div>
          <h2 class="reveal reveal-delay-1 font-bold leading-tight tracking-tight" style="font-size:clamp(1.75rem,4vw,3.25rem);color:#fff;letter-spacing:-0.02em;max-width:52rem">
            {s.whatHeading} <em style="font-family:var(--font-serif);font-weight:400;font-style:italic">{s.whatHeadingItalic}</em>
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" style="border-top:1px solid rgba(255,255,255,0.18)">
          {s.builds.map((b, i) => (
            <div
              class={`reveal reveal-delay-${Math.min(i+1,4)} flex flex-col gap-2 py-4 px-3 border-b`}
              style={`border-color:rgba(255,255,255,0.1);border-right:${(i+1)%4!==0 ? '1px solid rgba(255,255,255,0.1)' : 'none'}`}
            >
              <span style="font-family:var(--font-mono);font-size:0.55rem;letter-spacing:0.14em;color:var(--js-electric-blue);font-weight:700">{b.num}</span>
              <h3 class="font-bold leading-tight" style="font-size:clamp(0.9rem,1.3vw,1.05rem);color:#fff;letter-spacing:-0.01em">{b.name}</h3>
              <p class="leading-relaxed" style="color:rgba(255,255,255,0.65);font-size:0.78rem">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </InteractiveSection>

    <!-- ═══ PANEL 05: Por Qué JiveShed ═══ -->
    <InteractiveSection id="why" label={s.tabs[4].label} imageUrl="" overlayColor="var(--js-overlay-blue)">
      <div class="container-wide flex flex-col" style="gap:clamp(1.5rem,3vw,2.5rem)">
        <div>
          <div class="label-mono reveal mb-3" style="color:rgba(255,255,255,0.5)">{s.whyLabel}</div>
          <h2 class="reveal reveal-delay-1 font-bold leading-tight tracking-tight" style="font-size:clamp(2rem,5vw,4rem);color:#fff;letter-spacing:-0.02em;max-width:52rem">
            {s.whyHeading} <em style="font-family:var(--font-serif);font-weight:400;font-style:italic">{s.whyHeadingItalic}</em> {s.whyHeadingSuffix}
          </h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
          <div class="reveal reveal-delay-2 flex flex-col gap-3" style="padding:1.5rem;background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.12)">
            <span style="font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.14em;color:var(--js-electric-blue);font-weight:700">{s.aiLabel}</span>
            <h3 class="font-bold" style="font-size:clamp(1rem,1.6vw,1.25rem);color:#fff;letter-spacing:-0.01em">{s.aiTitle}</h3>
            <p style="color:rgba(255,255,255,0.7);font-size:0.85rem;line-height:1.6">{s.aiBody}</p>
          </div>
          <div class="reveal reveal-delay-3 flex flex-col gap-3" style="padding:1.5rem;background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.12)">
            <span style="font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.14em;color:var(--js-signal-green);font-weight:700">{s.humanLabel}</span>
            <h3 class="font-bold" style="font-size:clamp(1rem,1.6vw,1.25rem);color:#fff;letter-spacing:-0.01em">{s.humanTitle}</h3>
            <p style="color:rgba(255,255,255,0.7);font-size:0.85rem;line-height:1.6">{s.humanBody}</p>
          </div>
        </div>
      </div>
    </InteractiveSection>

    <!-- ═══ PANEL 06: CTA ═══ -->
    <InteractiveSection id="cta" label={s.tabs[5].label} imageUrl="" overlayColor="var(--js-overlay-green)">
      <div class="container-wide flex flex-col items-start justify-center" style="gap:clamp(1.5rem,3vw,2.5rem);min-height:60vh">
        <div class="label-mono reveal" style="color:rgba(255,255,255,0.5)">{s.ctaLabel}</div>
        <h2 class="reveal reveal-delay-1 font-bold leading-tight tracking-tight" style="font-size:clamp(2.25rem,7vw,6rem);color:#fff;letter-spacing:-0.02em;max-width:64rem">
          {s.ctaHeading} <em style="font-family:var(--font-serif);font-weight:400;font-style:italic">{s.ctaHeadingItalic}</em>
        </h2>
        <p class="reveal reveal-delay-2" style="color:rgba(255,255,255,0.8);font-size:clamp(0.95rem,1.4vw,1.15rem);line-height:1.6;max-width:42rem">
          {s.ctaBody}
        </p>
        <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
          <a href={`/${lang}/packages/`} class="sys-cta-primary inline-flex items-center gap-3 px-8 py-4" style="background:var(--js-coral);color:#fff;font-family:var(--font-mono);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase">
            {s.ctaCta1}
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href={`mailto:hello@jiveshed.com?subject=JiveShed%20Growth%20Audit`} class="sys-cta-outline inline-flex items-center gap-3 px-8 py-4" style="background:transparent;color:#fff;font-family:var(--font-mono);font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;border:1px solid rgba(255,255,255,0.7)">
            {s.ctaCta2}
          </a>
        </div>
      </div>
    </InteractiveSection>

  </main>
  <Footer taglineHtml={`${t.footer.tagline.replace(/^(.+)\s(\S+\.)$/, '$1 <em>$2</em>')}`} />
</Layout>

<style>
  .sys-cta-primary { transition: background 0.25s ease, color 0.25s ease, outline 0.25s ease; }
  .sys-cta-primary:hover { background: transparent !important; color: #fff !important; outline: 1px solid var(--js-coral); }
  .sys-cta-outline { transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease; }
  .sys-cta-outline:hover { background: #fff !important; color: #000 !important; border-color: #fff !important; }
</style>
