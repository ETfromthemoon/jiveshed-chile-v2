---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found | JiveShed Chile">
  <div class="min-h-screen flex flex-col items-center justify-center bg-[#0a0a0a] text-white px-6">
    <h1 class="text-8xl font-black text-[#FF3B00] mb-4">404</h1>
    <p class="text-2xl font-semibold mb-2">Page not found</p>
    <p class="text-white/60 mb-8">The content you're looking for doesn't exist or was moved.</p>
    <a href="/" class="bg-[#FF3B00] hover:bg-[#e03300] text-white font-bold px-8 py-3 rounded-full transition-colors">
      Back to home
    </a>
  </div>
</Layout>
